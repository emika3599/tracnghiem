rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitive Definition
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Only include isAdmin if the app explicitly requires it. 
    // The user nthithao1988bn@gmail.com is an admin.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "nthithao1988bn@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Entity Validation Helpers
    // ===============================================================

    function isValidQuizHistoryItem(data) {
      let fields = ['id', 'timestamp', 'title', 'score', 'totalQuestions', 'correctCount', 'timeSpent', 'quizData', 'userAnswers', 'userId'];
      return data.keys().hasAll(fields) &&
             isValidId(data.id) &&
             (data.timestamp is timestamp || data.timestamp is number) &&
             data.title is string && data.title.size() <= 500 &&
             data.score is number && data.score >= 0 && data.score <= 10.1 &&
             data.totalQuestions is number && data.totalQuestions > 0 &&
             data.correctCount is number && data.correctCount >= 0 &&
             data.timeSpent is number && data.timeSpent >= 0 &&
             data.quizData is map &&
             data.userAnswers is map &&
             data.userId == request.auth.uid;
    }

    function isValidSavedQuiz(data) {
      let requiredFields = ['id', 'title', 'timestamp', 'quizData', 'userId'];
      return data.keys().hasAll(requiredFields) &&
             isValidId(data.id) &&
             data.title is string && data.title.size() <= 500 &&
             (data.timestamp is timestamp || data.timestamp is number) &&
             data.quizData is map &&
             data.userId == request.auth.uid &&
             (!('folderId' in data) || data.folderId == null || (data.folderId is string && data.folderId.size() <= 128)) &&
             (!('userAnswers' in data) || data.userAnswers is map) &&
             (!('timeSpent' in data) || data.timeSpent is number);
    }

    function isValidFolder(data) {
      let fields = ['id', 'name', 'userId', 'timestamp'];
      return data.keys().hasAll(fields) && data.keys().size() == 4 &&
             isValidId(data.id) &&
             data.name is string && data.name.size() <= 100 &&
             data.userId == request.auth.uid &&
             (data.timestamp is timestamp || data.timestamp is number);
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    match /users/{userId} {
      // User profile level access (if any)
      allow read, write: if isOwner(userId) || isAdmin();

      match /history/{historyId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin(); 
        
        allow create: if isSignedIn() && isOwner(userId) && 
                         isValidId(historyId) && 
                         isValidQuizHistoryItem(incoming());
        
        allow update: if false; 
        
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /savedQuizzes/{quizId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        
        allow create: if isSignedIn() && isOwner(userId) && 
                         isValidId(quizId) && 
                         isValidSavedQuiz(incoming());
        
        allow update: if isSignedIn() && isOwner(userId) && 
                         isValidSavedQuiz(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().id == existing().id &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'timestamp', 'folderId', 'userAnswers', 'timeSpent']);
        
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /folders/{folderId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        
        allow create: if isSignedIn() && isOwner(userId) && 
                         isValidId(folderId) && 
                         isValidFolder(incoming());
        
        allow update: if isSignedIn() && isOwner(userId) && 
                         isValidFolder(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().id == existing().id &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['name']);
        
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
